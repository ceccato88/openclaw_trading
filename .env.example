# Hyperliquid
HYPERLIQUID_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
HYPERLIQUID_TESTNET=true
# Optional when using an API wallet to trade on behalf of a main account
HYPERLIQUID_ACCOUNT_ADDRESS=0xYOUR_ACCOUNT_ADDRESS

# Debate Arena local (required for LLM participants)
OPENROUTER_API_KEY=sk-or-your-key
DEBATE_MODEL_ID=openai/gpt-4o-mini
DEBATE_ALLOW_CHOP=false

# Local scheduler settings
# WOLF_POSITION_USD is now the minimum notional floor.
WOLF_HEARTBEAT_INTERVAL_SECONDS=180
WOLF_HUNT_INTERVAL_SECONDS=900
WOLF_POSITION_USD=25
WOLF_LEVERAGE=10
WOLF_RISK_PCT=2
WOLF_REWARD_PCT=4
WOLF_ACCOUNT_RISK_PCT=1
WOLF_MAX_DRAWDOWN_PCT=10
WOLF_MIN_VOLUME=5000000
WOLF_MAX_RESULTS=3
WOLF_MAX_CONSECUTIVE_FAILURES=3
WOLF_FAILURE_BACKOFF_SECONDS=60
